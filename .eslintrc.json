{
  "root": true,
  "ignorePatterns": ["node_modules/", "dist/", "build/"],
  "overrides": [
    {
      "files": ["api/**/*.js"],
      "env": {
        "node": true,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
      },
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_",
            "ignoreRestSiblings": true
          }
        ],
        "no-undef": "error"
      }
    },
    {
      "files": ["test/**/*.js"],
      "env": {
        "node": true,
        "es2022": true,
        "jest": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
      },
      "globals": {
        "window": "readonly",
        "document": "readonly",
        "localStorage": "readonly",
        "Blob": "readonly"
      },
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_",
            "ignoreRestSiblings": true
          }
        ],
        "no-undef": "error"
      }
    },
    {
      "files": ["js/**/*.js", "sw.js"],
      "env": {
        "browser": true,
        "worker": true,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
      },
      "globals": {
        "CONFIG": "readonly",
        "app": "readonly",
        "appNavigator": "readonly",
        "caches": "readonly",
        "displayName": "readonly",
        "driveAPI": "readonly",
        "encodeSegment": "readonly",
        "formatLevel": "readonly",
        "getDepartmentColor": "readonly",
        "CoverageRenderer": "readonly",
        "lucide": "readonly",
        "module": "readonly",
        "notificationHelper": "readonly",
        "pathCache": "readonly",
        "pwaManager": "readonly",
        "renderer": "readonly",
        "contactModalHelper": "readonly",
        "TeamRenderer": "readonly",
        "self": "readonly"
      },
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ],
        "no-undef": "error",
        "consistent-return": "error"
      }
    }
  ]
}
