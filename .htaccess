# ──────────────────────────────────────────────────────────────────────
# CURB — .htaccess for cPanel PHP Hosting
# Rewrites clean /api/* URLs to their .php handlers and applies
# security headers equivalent to vercel.json.
# ──────────────────────────────────────────────────────────────────────

# Enable rewrite engine
RewriteEngine On

# ──────────────────────────────────────────────────────────────────────
# API Endpoint Rewrites
# Maps clean URLs to PHP files so the frontend needs no code changes.
#   /api/browse   → /api/browse.php
#   /api/coverage → /api/coverage.php
#   /api/team     → /api/team.php
# ──────────────────────────────────────────────────────────────────────

RewriteRule ^api/browse$   api/browse.php   [L,QSA]
RewriteRule ^api/coverage$ api/coverage.php [L,QSA]
RewriteRule ^api/team$     api/team.php     [L,QSA]

# ──────────────────────────────────────────────────────────────────────
# Block direct access to internal PHP files (config, utils, cache)
# ──────────────────────────────────────────────────────────────────────

RewriteRule ^api/_.*$ - [F,L]
RewriteRule ^api/_cache/ - [F,L]

# ──────────────────────────────────────────────────────────────────────
# SPA Fallback — serve index.html for any non-file, non-API route
# ──────────────────────────────────────────────────────────────────────

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule . /index.html [L]

# ──────────────────────────────────────────────────────────────────────
# Security Headers (equivalent to vercel.json)
# ──────────────────────────────────────────────────────────────────────

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ──────────────────────────────────────────────────────────────────────
# Service Worker Header
# ──────────────────────────────────────────────────────────────────────

<IfModule mod_headers.c>
    <Files "sw.js">
        Header set Cache-Control "public, max-age=0, must-revalidate"
        Header set Service-Worker-Allowed "/"
    </Files>
</IfModule>

# ──────────────────────────────────────────────────────────────────────
# Prevent directory listing
# ──────────────────────────────────────────────────────────────────────

Options -Indexes

# ──────────────────────────────────────────────────────────────────────
# Block access to sensitive files
# ──────────────────────────────────────────────────────────────────────

<FilesMatch "^\.env|\.git|\.gitignore|package\.json|package-lock\.json|vercel\.json|server\.js$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
